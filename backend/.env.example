XAI_API_KEY=your_xai_api_key_here
OPENWEATHER_API_KEY=your_openweather_key_here
DATABASE_URL=sqlite:///./blackrabbit.db

# Stripe — leave blank for demo payment mode
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_MODE=test
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=http://localhost:8081

# Email verification — demo mode logs codes to the server console
EMAIL_DEMO_MODE=true
EMAIL_CODE_TTL_MINUTES=15
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_CODE_SECRET=change-me-in-production

# SMTP (optional — when blank, demo mode is used)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@blackrabbit.services
# xAI chat (Grok)
XAI_API_KEY=your_xai_api_key_here
XAI_CHAT_MODEL=grok-4.5
